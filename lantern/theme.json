{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 2,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "720px",
            "wideSize": "1240px"
        },
        "color": {
            "background": true,
            "custom": true,
            "customGradient": true,
            "defaultPalette": false,
            "defaultGradients": false,
            "palette": [
                { "name": "Paper",        "slug": "paper",        "color": "#f7f1e6" },
                { "name": "Paper Deep",   "slug": "paper-deep",   "color": "#efe6d3" },
                { "name": "Ink",          "slug": "ink",          "color": "#1a2538" },
                { "name": "Ink Soft",     "slug": "ink-soft",     "color": "#2c3a52" },
                { "name": "Ember",        "slug": "ember",        "color": "#c7572b" },
                { "name": "Ember Deep",   "slug": "ember-deep",   "color": "#9d3e1a" },
                { "name": "Sage",         "slug": "sage",         "color": "#5d7561" },
                { "name": "Sand",         "slug": "sand",         "color": "#d9c79a" },
                { "name": "Gold",         "slug": "gold",         "color": "#b7892b" }
            ],
            "gradients": [
                {
                    "name": "Dawn",
                    "slug": "dawn",
                    "gradient": "linear-gradient(135deg, #f7f1e6 0%, #efe6d3 100%)"
                },
                {
                    "name": "Ink to Ember",
                    "slug": "ink-ember",
                    "gradient": "linear-gradient(135deg, #1a2538 0%, #c7572b 100%)"
                }
            ]
        },
        "typography": {
            "fluid": true,
            "fontFamilies": [
                {
                    "fontFamily": "\"Fraunces\", \"Iowan Old Style\", Georgia, serif",
                    "name": "Display (Fraunces)",
                    "slug": "display"
                },
                {
                    "fontFamily": "\"Instrument Sans\", ui-sans-serif, system-ui, sans-serif",
                    "name": "Body (Instrument Sans)",
                    "slug": "body"
                },
                {
                    "fontFamily": "\"JetBrains Mono\", ui-monospace, monospace",
                    "name": "Mono",
                    "slug": "mono"
                }
            ],
            "fontSizes": [
                { "name": "Small",   "slug": "small",   "size": "0.94rem" },
                { "name": "Regular", "slug": "regular", "size": "1.06rem" },
                { "name": "Medium",  "slug": "medium",  "size": "1.31rem" },
                { "name": "Large",   "slug": "large",   "size": "1.69rem" },
                { "name": "X-Large", "slug": "x-large", "size": "2.28rem" },
                { "name": "Display", "slug": "display", "size": "4.4rem" }
            ]
        },
        "spacing": {
            "padding": true,
            "margin": true,
            "blockGap": true,
            "units": [ "px", "em", "rem", "%", "vh", "vw" ]
        }
    },
    "styles": {
        "color": {
            "background": "var(--lantern-paper, #f7f1e6)",
            "text": "var(--lantern-ink, #1a2538)"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|body",
            "fontSize": "1.06rem",
            "lineHeight": "1.65"
        },
        "elements": {
            "h1": { "typography": { "fontFamily": "var:preset|font-family|display", "fontWeight": "460", "lineHeight": "1.05" } },
            "h2": { "typography": { "fontFamily": "var:preset|font-family|display", "fontWeight": "460", "lineHeight": "1.05" } },
            "h3": { "typography": { "fontFamily": "var:preset|font-family|display", "fontWeight": "460", "lineHeight": "1.1" } },
            "h4": { "typography": { "fontFamily": "var:preset|font-family|display", "fontWeight": "500", "lineHeight": "1.15" } },
            "link": {
                "color": { "text": "var(--lantern-ink, #1a2538)" },
                ":hover": { "color": { "text": "var(--lantern-ember, #c7572b)" } }
            },
            "button": {
                "color": {
                    "background": "var(--lantern-ink, #1a2538)",
                    "text": "var(--lantern-paper, #f7f1e6)"
                },
                "border": { "radius": "999px" },
                "spacing": { "padding": { "top": "0.85rem", "bottom": "0.85rem", "left": "1.4rem", "right": "1.4rem" } },
                ":hover": {
                    "color": {
                        "background": "var(--lantern-ember, #c7572b)",
                        "text": "var(--lantern-paper, #f7f1e6)"
                    }
                }
            }
        }
    },
    "customTemplates": [
        { "name": "meeting-finder", "title": "Meeting Finder",    "postTypes": [ "page" ] },
        { "name": "events",         "title": "Events",            "postTypes": [ "page" ] },
        { "name": "cleantime",      "title": "Cleantime Calculator", "postTypes": [ "page" ] },
        { "name": "meditation",     "title": "Daily Meditation",  "postTypes": [ "page" ] },
        { "name": "helpline",       "title": "Helpline",          "postTypes": [ "page" ] },
        { "name": "for-public",     "title": "For the Public",    "postTypes": [ "page" ] },
        { "name": "for-members",    "title": "For Members",       "postTypes": [ "page" ] },
        { "name": "wide",           "title": "Wide (full-bleed content)", "postTypes": [ "page", "post" ] }
    ]
}
